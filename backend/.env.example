# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/room_kiosk.db
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Payments ──────────────────────────────────────────────────────────────────
UPI_ID=hotel@upi
UPI_PAYEE_NAME=Hotel Reception

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hotel.local

# ── WhatsApp (optional stub) ──────────────────────────────────────────────────
WHATSAPP_API_KEY=
WHATSAPP_API_URL=

# ── Kiosk behaviour ───────────────────────────────────────────────────────────
KIOSK_INACTIVITY_SECONDS=60
BOOKING_HOLD_MINUTES=30
ID_PURGE_DAYS=30

# ── Google Cloud Vision OCR ───────────────────────────────────────────────────
# Path to service-account JSON (relative to backend/ or absolute)
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-vision-sa.json

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# Path to Firebase Admin SDK service-account JSON
FIREBASE_CREDENTIALS_PATH=credentials/firebase-adminsdk.json
FIREBASE_PROJECT_ID=dome-cf56b

# ── MQTT Door Lock ────────────────────────────────────────────────────────────
# HiveMQ Cloud (or any MQTT broker). Leave MQTT_HOST blank to disable MQTT.
MQTT_HOST=your-cluster.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=dome-backend
MQTT_PASSWORD=change-me
MQTT_TLS=true
MQTT_TOPIC_PREFIX=dome/room
# How long (minutes) the door stays unlocked after payment confirmed
ROOM_UNLOCK_MINUTES=120

# ── AiSensy WhatsApp API ─────────────────────────────────────────────────────
AISENSY_API_KEY=
AISENSY_USER_NAME=Hotel Reception
AISENSY_CAMPAIGN_CHECKIN=checkin_confirmation
AISENSY_CAMPAIGN_CHECKOUT_REMINDER=checkout_reminder
AISENSY_CAMPAIGN_PAYMENT=payment_receipt
AISENSY_CAMPAIGN_NEW_BOOKING=new_booking_alert
AISENSY_CAMPAIGN_OVERSTAY=overstay_alert
AISENSY_ADMIN_PHONE=918966051698

# ── MSG91 Campaign / Flow API ─────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_CHECKIN_SUCCESS_FLOW=
MSG91_CHECKIN_FAILED_FLOW=
MSG91_SENDER_ID=HOTEL
MSG91_ADMIN_PHONE=918966051698
